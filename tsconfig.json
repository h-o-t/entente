{
  "compilerOptions": {
    "lib": ["ES2022", "deno.ns"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": ["./src/**/*", "./tests/**/*"]
}
